{
  "name": "@navigatr/core",
  "version": "1.0.0",
  "description": "Pure TypeScript routing and geocoding SDK using Valhalla and Nominatim",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "keywords": [
    "maps",
    "routing",
    "geocoding",
    "valhalla",
    "nominatim",
    "openstreetmap"
  ],
  "license": "MIT"
}
