{
  "name": "@navigatr/mobile",
  "version": "1.2.0",
  "description": "React Native SDK for maps, routing, and navigation with react-native-maps",
  "author": "capeku",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/capeku/navigatr.git",
    "directory": "packages/mobile"
  },
  "homepage": "https://github.com/capeku/navigatr#readme",
  "bugs": {
    "url": "https://github.com/capeku/navigatr/issues"
  },
  "main": "./dist/index.js",
