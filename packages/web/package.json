{
  "name": "@navigatr/web",
  "version": "1.0.0",
  "description": "Browser SDK for Navigatr with Leaflet map rendering",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@navigatr/core": "workspace:*",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.8",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "maps",
    "leaflet",
    "routing",
    "geocoding",
    "openstreetmap"
  ],
  "license": "MIT"
}
