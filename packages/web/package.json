{
  "name": "@navigatr/web",
  "version": "1.0.0",
  "description": "Browser SDK for Navigatr with MapLibre GL JS map rendering",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "embed-css": "node scripts/embed-css.mjs",
    "build": "node scripts/embed-css.mjs && tsc",
    "dev": "node scripts/embed-css.mjs && tsc --watch"
  },
  "dependencies": {
    "@navigatr/core": "workspace:*",
    "maplibre-gl": "^4.5.0",
    "@turf/nearest-point-on-line": "^7.1.0",
    "@turf/bearing": "^7.1.0",
    "@turf/distance": "^7.1.0",
    "@turf/helpers": "^7.1.0",
    "@turf/along": "^7.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "keywords": [
    "maps",
    "maplibre",
    "routing",
    "geocoding",
    "openstreetmap",
    "navigation"
  ],
  "license": "MIT"
}
